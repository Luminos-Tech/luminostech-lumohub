# URL backend cho proxy /api/v1/* (server-side, đọc lúc chạy).
INTERNAL_API_URL=http://127.0.0.1:8000
# Optional: override WebSocket origin; if unset, public pages use wss://api.<your-apex-domain>
# NEXT_PUBLIC_WS_URL=wss://api.example.com

# Gemini API key để trích xuất sự kiện từ ảnh/text
GEMINI_API_KEY=your_gemini_api_key_here
